# ─── Twilio Credentials ───────────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_NUMBER=+1XXXXXXXXXX        # Your Twilio virtual number

# ─── Base URL (set to your Vercel deployment URL after deploying) ─────────────
BASE_URL=https://your-project.vercel.app

# ─── Agent Phone Numbers (who receives the calls) ─────────────────────────────
AGENT_1=+91XXXXXXXXXX             # Default / general agent
AGENT_SALES=+91XXXXXXXXXX         # Sales team (Press 1)
AGENT_SUPPORT=+91XXXXXXXXXX       # Support team (Press 2)
AGENT_2=+91XXXXXXXXXX
AGENT_3=+91XXXXXXXXXX

# ─── Custom IVR Greeting (optional) ──────────────────────────────────────────
IVR_GREETING=Welcome! Thank you for calling. Press 1 for Sales. Press 2 for Support. Press 3 for Order Status. Press 0 to speak with an agent.
